def get_device():
    if not torch.cuda.is_available():
        logger.warning("CUDA unavailable — using CPU"); return torch.device("cpu")
    try:
        cap=torch.cuda.get_device_capability(0); name=torch.cuda.get_device_name(0)
        logger.info(f"GPU: {name} | sm_{cap[0]}{cap[1]}")
        if cap[0]<7:
            logger.warning("GPU compute < 7.0 — falling back to CPU"); return torch.device("cpu")
        return torch.device("cuda")
    except Exception as e:
        logger.warning(f"CUDA error: {e} — using CPU"); return torch.device("cpu")
